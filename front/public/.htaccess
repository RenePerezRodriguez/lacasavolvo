RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# SPA fallback — todas las rutas al index.html
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# ═══ CACHE CONTROL ═══
<IfModule mod_headers.c>
  # index.html y version.json NUNCA se cachean — index.html siempre trae el bundle
  # más reciente; version.json es la sonda que detecta una versión nueva (debe llegar
  # fresco al navegador para disparar el overlay de "recargá").
  <FilesMatch "(index\.html|version\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Assets con hash → inmutables, cache agresivo (1 año)
  # Vite genera nombres únicos (index-AbC123.js) así que es seguro
  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|gif|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
</IfModule>

# Comprimir respuestas
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
