# Credenciales para los tests E2E de Playwright (front/e2e/).
# Copiá este archivo a `.env.e2e` y completá con credenciales de un entorno de PRUEBA.
# NUNCA uses credenciales de producción. `.env.e2e` está gitignored.
#
#   cp .env.e2e.example .env.e2e

E2E_ADMIN_EMAIL=admin@example.test
E2E_ADMIN_PASS=

E2E_VENDEDOR_EMAIL=vendedor@example.test
E2E_VENDEDOR_PASS=
