# ── Credenciales de deploy — La Casa Volvo ──────────────────────────────────
# Copiá este archivo a `.deploy.env` (en esta misma carpeta) y completá los
# valores reales. `.deploy.env` está gitignored: NUNCA se commitea.
# Lo leen: upload-ftp.ps1 y create-admin-legacy.php

# ── FTP API (api.lacasavolvo.com) ──
LCV_FTP_HOST=ftp.lacasavolvo.com
LCV_FTP_USER=backend@api.lacasavolvo.com
LCV_FTP_PASS=

# ── FTP Staging (staging.lacasavolvo.com) ──
LCV_STAGING_FTP_USER=staging@staging.lacasavolvo.com
LCV_STAGING_FTP_PASS=

# ── FTP Producción frontend (lacasavolvo.com) ──
LCV_PROD_FTP_HOST=ftp.lacasavolvo.com
LCV_PROD_FTP_USER=prod@lacasavolvo.com
LCV_PROD_FTP_PASS=

# ── BD legacy (create-admin-legacy.php) ──
LCV_DB_HOST=localhost
LCV_DB_PORT=3306
LCV_DB_NAME=tienda
LCV_DB_USER=userjavi
LCV_DB_PASS=

# ── Password de usuarios de prueba (create-users.php / setup.php en BD vacía) ──
# Solo se usa para sembrar usuarios en una BD nueva/vacía. En producción los
# usuarios reales vienen en la copia de `tienda`, así que esto puede quedar vacío.
SEED_ADMIN_PASSWORD=

# ── cPanel API token (UAPI sobre HTTPS 2083) — para crear/gestionar BD por API ──
CPANEL_USER=lacasavo
CPANEL_API_TOKEN=

# ── (Opcional) Ruta local de api/ para upload-ftp.ps1 ──
# LCV_API_LOCAL=d:\Sitios Web\lacasavolvo\api
