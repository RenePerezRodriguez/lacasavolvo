# ── Credenciales de deploy — La Casa Volvo ──────────────────────────────────
# Copiá este archivo a `.deploy.env` (misma carpeta) y completá los valores reales.
# `.deploy.env` está gitignored: NUNCA se commitea.
# Lo leen: deploy-cpanel-api.sh y create-admin-legacy.php
#
# El deploy es por la API de cPanel (UAPI :2083) — NO FTP. Ver docs/DEPLOY.md.

# ── cPanel API token (UAPI sobre HTTPS :2083) — deploy de código + SPA + BD ──
CPANEL_USER=tu_usuario_cpanel
CPANEL_API_TOKEN=

# ── BD legacy (create-admin-legacy.php) ──
LCV_DB_HOST=localhost
LCV_DB_PORT=3306
LCV_DB_NAME=nombre_db_local
LCV_DB_USER=tu_usuario_db
LCV_DB_PASS=

# ── Password de usuarios de prueba (create-users.php / setup.php en BD vacía) ──
# Solo para sembrar usuarios en una BD nueva/vacía. En producción los usuarios reales
# vienen en la copia de `tienda`, así que esto puede quedar vacío.
SEED_ADMIN_PASSWORD=
